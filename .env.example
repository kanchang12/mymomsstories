DATABASE_URL=postgresql://user:password@host/dbname
GEMINI_API_KEY=your_gemini_api_key_here
SECRET_KEY=change-this-to-a-long-random-string

# PayPal — £15/month flat subscription, auto-provisions product+plan on first use.
# 7-day free trial auto-starts at registration, no PayPal creds needed during trial.
# Get these from your PayPal Developer dashboard → My Apps & Credentials.
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox
# Set after adding webhook in PayPal dashboard (optional in dev — skips signature check if blank)
PAYPAL_WEBHOOK_ID=

# To create your first admin account after deploy, run:
#   python3 scripts/create_admin.py admin@yourdomain.com yourpassword
# Then log in at /auth/login — you'll land on /admin automatically.

# Admin account — auto-created on first boot if these are set.
# Safe to leave in permanently; only creates the account once (skips if email already exists).
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=changethis
