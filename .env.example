DATABASE_URL=postgresql://user:password@host/dbname
GEMINI_API_KEY=your_gemini_api_key_here
SECRET_KEY=change-this-to-a-long-random-string

# Stripe — £15/month flat subscription, auto-provisions product+price on first use.
# 7-day free trial auto-starts at registration, no Stripe creds needed during trial.
# Get the secret key from your Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=sk_live_or_sk_test_your_stripe_secret_key
# Get this after adding a webhook endpoint in Stripe Dashboard → Developers → Webhooks,
# pointed at https://yourdomain.com/webhooks/stripe, listening for:
#   checkout.session.completed, invoice.paid, invoice.payment_failed,
#   customer.subscription.deleted, customer.subscription.updated
# (optional in dev — skips signature check if blank)
STRIPE_WEBHOOK_SECRET=

# To create your first admin account after deploy, run:
#   python3 scripts/create_admin.py admin@yourdomain.com yourpassword
# Then log in at /auth/login — you'll land on /admin automatically.

# Admin account — auto-created on first boot if these are set.
# Safe to leave in permanently; only creates the account once (skips if email already exists).
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=changethis

# Free public video section (/videos) — no login required.
# Create a playlist on YouTube, add your story videos to it, then set this
# to the playlist ID (the part after "list=" in the playlist URL):
#   youtube.com/playlist?list=PLxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_PLAYLIST_ID=

# For multi-language support, add extra audio tracks to each video in
# YouTube Studio (Subtitles > Languages, or Audio Tracks) — viewers switch
# language from the player's own settings gear, no extra setup needed here.
